<?xml version="1.0" encoding="UTF-8"?>
<project name="ParqueoPublico-impl" default="default" basedir="..">
    <fail unless="ant.file.ParqueoPublico" message="Este archivo debe ejecutarse mediante build.xml"/>

    <property file="nbproject/project.properties"/>

    <target name="-init">
        <mkdir dir="${build.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>

    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <target name="compile" depends="-init">
        <javac
            srcdir="${src.dir}"
            destdir="${build.classes.dir}"
            includeantruntime="false"
            source="${javac.source}"
            target="${javac.target}"
            encoding="${source.encoding}">
            <classpath path="${javac.classpath}"/>
        </javac>
        <copy todir="${build.classes.dir}">
            <fileset dir="${src.dir}" excludes="**/*.java"/>
        </copy>
    </target>

    <target name="jar" depends="clean,compile">
        <jar jarfile="${dist.jar}" manifest="${manifest.file}" compress="${jar.compress}">
            <fileset dir="${build.classes.dir}"/>
        </jar>
    </target>

    <target name="run" depends="compile">
        <java classname="${main.class}" fork="true" failonerror="true">
            <classpath path="${run.classpath}"/>
            <jvmarg line="${run.jvmargs}"/>
        </java>
    </target>

    <target name="default" depends="jar"/>
    <target name="test">
        <echo message="No hay pruebas configuradas en este proyecto."/>
    </target>
</project>
